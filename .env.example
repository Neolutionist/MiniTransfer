# ========================================================================
# MiniTransfer – Environment variabelen
# ========================================================================
# Kopieer dit bestand naar .env (voor lokaal) of zet ze in Render → Environment.
# Zet NOOIT echte waarden in dit bestand als het in git komt; gebruik .env.example
# als documentatie en .env (gitignored) voor lokale waarden.
# ========================================================================

# --- Authenticatie (login voor /upload) ----------------------------------
# E-mailadres waarmee je inlogt.
AUTH_EMAIL=

# Gegenereerde hash van je wachtwoord (AANBEVOLEN). Genereer lokaal:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('JouwWachtwoord'))"
AUTH_PASSWORD_HASH=

# Legacy: plaintext wachtwoord (alleen als AUTH_PASSWORD_HASH niet gezet is).
# Niet aanbevolen; migreer naar AUTH_PASSWORD_HASH.
# AUTH_PASSWORD=

# Brute-force instellingen (optioneel, hebben veilige defaults)
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=300
# LOGIN_LOCKOUT_SECONDS=900

# --- Flask ---------------------------------------------------------------
# Willekeurige lange string voor session cookies. In Render kun je dit met
# `generateValue: true` automatisch laten genereren.
SECRET_KEY=

# --- Hosts / tenant ------------------------------------------------------
# Het canonieke domein waarop de app draait (bijv. voorbeeld.example.com).
CANONICAL_HOST=

# Optioneel: oud domein waar vanaf je redirect naar CANONICAL_HOST.
# OLD_HOST=oude-app.onrender.com

# Optioneel: expliciete tenant-slug en -host. Als leeg worden ze afgeleid
# uit CANONICAL_HOST.
# TENANT_HOST=
# TENANT_SLUG=

# Optioneel: basishost voor subdomein-voorbeeldlinks in /contact.
# Als leeg, afgeleid van CANONICAL_HOST (laatste 2 delen).
# BASE_HOST=example.com

# --- Data directory ------------------------------------------------------
# Pad waar de SQLite-database wordt opgeslagen (moet persistent zijn).
DATA_DIR=/var/data

# --- S3 / object storage (Backblaze B2 of AWS S3) ------------------------
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=eu-central-003
# AWS_ACCESS_KEY_ID en AWS_SECRET_ACCESS_KEY komen uit standaard boto3-env:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- SMTP (voor notificatie-mails) --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Waar notificatie-mails naartoe gestuurd worden (contactformulier, PayPal, etc.)
MAIL_TO=

# --- PayPal (abonnementen) -----------------------------------------------
# Live: https://api-m.paypal.com  |  Sandbox: https://api-m.sandbox.paypal.com
PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Plan-IDs uit PayPal Developer Dashboard
PAYPAL_PLAN_0_5=
PAYPAL_PLAN_1=
PAYPAL_PLAN_2=
PAYPAL_PLAN_5=

# --- Interne cron-endpoint ----------------------------------------------
# Token om /internal/cleanup te beschermen.
TASK_TOKEN=

# --- Upload limieten (optioneel) ----------------------------------------
# MAX_CONTENT_LENGTH=21474836480   # 20 GB in bytes
# MIN_EXPIRY_DAYS=0.04             # ~1 uur minimum
# MAX_EXPIRY_DAYS=365

# --- Debug (standaard uit) ----------------------------------------------
# Alleen op 1 zetten tijdens lokaal debuggen. NOOIT in productie.
# ENABLE_DEBUG_ROUTES=0

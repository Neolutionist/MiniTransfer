# ========================================================================
# MiniTransfer – .gitignore
# ========================================================================

# Secrets & env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/

# Lokale SQLite-database & WAL files
*.db
*.db-journal
*.db-wal
*.db-shm
files_multi.db*

# Lokale data-map (uploads, exports)
data/
uploads/
/var/data/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Coverage / tests
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# Render / deploy artefacts
.render/
